# site.toml — instance configuration for your portfolio
# Copy to site.toml and edit. site.toml is gitignored (it's yours, not the tool's).

title       = "~/tools"
description = "Tools & Projects"
footer      = 'Built with <a href="https://tools.vandragt.com/toolhub/">ToolHub</a>'
# url is the canonical URL of this site.
# Used as the base for Atom feed <id>/<link> elements, and to auto-detect
# a backlink to the parent domain in the site header.
# Set to your deployed site URL (no trailing slash).
url         = "https://example.github.io"
# author name used in the Atom feed; defaults to GH_USERNAME if not set.
author      = "Your Name"

[navigation]
# back_link_url: URL shown as a "← Home" link in the site header.
# Leave empty to auto-derive from url (subdomain or subdirectory deployments).
# Set explicitly for edge cases, e.g. GitHub Pages: "https://username.github.io"
back_link_url   = ""
# Label for the back link (default: "Home").
back_link_label = "Home"

[sections]
active    = "Active projects"
archived  = "Archived"
back_link = "all projects"

[feed]
# Maximum number of entries in feed.xml, sorted by most-recently-released.
max_entries = 20

[theme]
# Point at your own templates/ and static/ to use a custom theme.
# Paths are relative to the repo root.
templates_dir = "templates"
static_dir    = "static"
