# site.toml — instance configuration for your portfolio
# Copy to site.toml and edit. site.toml is gitignored (it's yours, not the tool's).

title       = "~/tools"
description = "Tools & Projects"
footer      = 'Built with <a href="https://tools.vandragt.com/toolhub/">ToolHub</a>'
# url is used as the base for Atom feed <id> and <link> elements.
# Set this to your deployed site URL (no trailing slash).
url         = "https://example.github.io"
# author name used in the Atom feed; defaults to GH_USERNAME if not set.
author      = "Your Name"

[sections]
active    = "Active projects"
archived  = "Archived"
back_link = "all projects"

[feed]
# Maximum number of entries in feed.xml, sorted by most-recently-released.
max_entries = 20

[theme]
# Point at your own templates/ and static/ to use a custom theme.
# Paths are relative to the repo root.
templates_dir = "templates"
static_dir    = "static"
