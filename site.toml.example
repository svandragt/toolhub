# site.toml — instance configuration for your portfolio
# Copy to site.toml and edit. site.toml is gitignored (it's yours, not the tool's).

title       = "~/tools"
description = "Tools & Projects"
footer      = 'Built with <a href="https://tools.vandragt.com/toolhub/">ToolHub</a>'
# base_url is used for absolute URLs in the Atom feed (no trailing slash).
# Required for feed entries to link correctly when consumed by feed readers.
base_url    = "https://example.github.io/toolhub"

# URL of this toolhub site — used to auto-detect a backlink to the parent domain.
# e.g. if site_url = "https://tools.example.com", back_link_url defaults to "https://example.com"
site_url = ""

[navigation]
back_link_url   = ""      # leave empty to auto-derive from site_url, or set explicitly
back_link_label = "Home"

[sections]
active    = "Active projects"
archived  = "Archived"
back_link = "all projects"

[theme]
# Point at your own templates/ and static/ to use a custom theme.
# Paths are relative to the repo root.
templates_dir = "templates"
static_dir    = "static"
